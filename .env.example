PORT=5000

DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false

# Generate a strong random value for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=12h

# Comma-separated list of allowed frontend origins, e.g. http://localhost:3000
CORS_ORIGIN=http://localhost:3000
